# --- App ---
APP_ENV=development                 # development | staging | production
APP_NAME=zenova-backend
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database (Supabase Postgres pooled connection) ---
# Get this from Supabase: Project Settings -> Database -> Connection string -> URI
# Use the "Connection pooling" URI for runtime (port 6543) and the "Direct connection"
# URI for migrations (port 5432). Both work via asyncpg.
DATABASE_URL=postgresql+asyncpg://postgres:password@db.PROJECT.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg://postgres:password@db.PROJECT.supabase.co:5432/postgres
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800

# --- Auth (custom JWT) ---
# REQUIRED: 64+ random chars. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=720           # 12h — admin sessions
JWT_REFRESH_TTL_DAYS=30
BCRYPT_ROUNDS=12

# --- CORS ---
# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,https://whitedevil-141.github.io

# --- Rate limiting ---
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_DEFAULT=120/minute

# --- Cloudflare R2 (S3-compatible) for image uploads ---
# Create an R2 bucket and an API token (Object Read & Write) at dash.cloudflare.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=zenova-media
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# Public hostname that serves the bucket (custom domain or *.r2.dev). Without trailing slash.
R2_PUBLIC_BASE=https://media.zenova.agency
R2_MAX_UPLOAD_MB=10
